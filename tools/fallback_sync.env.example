# info-beamer API key (account-level token with setup/asset permissions)
IB_API_KEY=ib_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Package ID of this in-store radio package on info-beamer
IB_PACKAGE_ID=51388

# Source server connection (where monthly fallback MP3 is produced)
SRC_SSH_KEY=/Users/youruser/.ssh/NY_AWS_KEY.pem
SRC_SSH_USER=ubuntu
SRC_SSH_HOST=52.58.95.110
SRC_REMOTE_DIR=/media/fallback/output

# Pattern for the newest monthly fallback file
SRC_REMOTE_PATTERN=*_NewYorker_fallback_INTohneSpot_short.mp3
