#!/usr/bin/env python3
import datetime
import json
import os
import time
import urllib.request

CONFIG_FILE = "config.json"
META_FILE = "stream_meta.json"
CHECK_FILE = "stream_check.json"
REFRESH_FILE = "refresh.request"

DEFAULT_URL = "http://dressfm.streamabc.net/flx-dressfmgermany-mp3-128-2541368?aggregator=nystore"


def now_iso():
    return datetime.datetime.utcnow().replace(microsecond=0).isoformat() + "Z"


def atomic_json_write(path, payload):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(payload, f)
    os.replace(tmp, path)


def load_config_url():
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as f:
            cfg = json.load(f)
            return cfg.get("stream_url") or DEFAULT_URL
    except Exception:
        return DEFAULT_URL


def write_meta(title, error=None):
    payload = {
        "title": title or "-",
        "updated_at": now_iso(),
    }
    if error:
        payload["error"] = error
    atomic_json_write(META_FILE, payload)


def write_check(url, ok, message):
    payload = {
        "url": url,
        "ok": bool(ok),
        "message": message,
        "updated_at": now_iso(),
    }
    atomic_json_write(CHECK_FILE, payload)


def parse_stream_title(meta_bytes):
    if not meta_bytes:
        return None
    text = meta_bytes.decode("latin-1", "ignore")
    marker = "StreamTitle='"
    start = text.find(marker)
    if start < 0:
        return None
    start += len(marker)
    end = text.find("';", start)
    if end < 0:
        return None
    return text[start:end].strip() or None


def fetch_icy_title(url, timeout=12):
    req = urllib.request.Request(
        url,
        headers={
            "Icy-MetaData": "1",
            "User-Agent": "info-beamer-stream-meta/1.0",
        },
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        metaint = resp.headers.get("icy-metaint")
        content_type = resp.headers.get("content-type", "")
        if not metaint:
            return None, content_type
        metaint = int(metaint)

        _ = resp.read(metaint)
        raw_len = resp.read(1)
        if not raw_len:
            return None, content_type
        meta_len = raw_len[0] * 16
        meta = resp.read(meta_len)
        return parse_stream_title(meta), content_type


def touched(path, last_mtime):
    try:
        mtime = os.path.getmtime(path)
    except OSError:
        return False, last_mtime
    if last_mtime is None or mtime > last_mtime:
        return True, mtime
    return False, last_mtime


def main():
    write_check("-", False, "Service started, waiting for first stream check")
    last_refresh_mtime = None
    last_url = None
    last_poll = 0

    while True:
        now = time.time()
        url = load_config_url()

        must_refresh = False

        changed, last_refresh_mtime = touched(REFRESH_FILE, last_refresh_mtime)
        if changed:
            must_refresh = True

        if url != last_url:
            must_refresh = True
            last_url = url

        if now - last_poll > 30:
            must_refresh = True

        if must_refresh:
            last_poll = now
            try:
                title, content_type = fetch_icy_title(url)
                if title:
                    write_meta(title)
                else:
                    write_meta("(no stream title)")
                write_check(url, True, "Reachable. content-type=" + (content_type or "unknown"))
            except Exception as err:
                write_meta("-", error=str(err))
                write_check(url, False, str(err))

        time.sleep(1)


if __name__ == "__main__":
    main()
